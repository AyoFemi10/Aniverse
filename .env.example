# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Requests per minute per IP
RATE_LIMIT_MAX=100

# ─── HTTP ─────────────────────────────────────────────────────────────────────
# Scraper request timeout in milliseconds
REQUEST_TIMEOUT_MS=15000

# ─── Logging ──────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─── Public URL (used to build absolute proxy image URLs) ────────────────────
# Set this to your public domain so image fields contain full absolute URLs.
# Example: PUBLIC_URL=https://apis.ayohost.site
PUBLIC_URL=https://apis.ayohost.site
# Comma-separated list of allowed origins. Leave empty to allow all.
# ALLOWED_ORIGINS=https://myapp.com,https://staging.myapp.com

# ─── Scraper Proxy ────────────────────────────────────────────────────────────
# Residential proxy to bypass Cloudflare IP blocks on the upstream scrape target.
# Format: http://username:password@host:port
# Recommended: webshare.io (cheapest), brightdata.com, oxylabs.io
# SCRAPER_PROXY=http://user:pass@proxy.example.com:8080

# ─── Cloudflare Worker Proxy ──────────────────────────────────────────────────
# Deploy the worker from docs/cf-worker.js to workers.cloudflare.com (free tier)
# then set this URL. Requests to the upstream site are routed through CF's network.
# SCRAPER_PROXY_WORKER=https://aniverse-proxy.yourname.workers.dev
